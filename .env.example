# Environment Variables
# Change this for production deployment (e.g., set to a persistent SQLite path or PostgreSQL URL)
# Example for Render's Persistent Disk: sqlite:////opt/render/project/src/data/export_marketplace.db
DATABASE_URL=sqlite:///./export_marketplace.db

# Optional: Add JWT secret or other keys here
SECRET_KEY=yoursecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
